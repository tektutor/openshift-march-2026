pipeline {
    agent {
        kubernetes {
            yaml """
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: java-agent
    image: registry.access.redhat.com/ubi8/openjdk-17:latest
    command: ['cat']
    tty: true
  - name: oc-client
    image: quay.io/openshift/origin-cli:latest
    command: ['cat']
    tty: true
  volumeMounts:
  - name: m2-cache
    mountPath: /home/jenkins/.m2
  volumes:
  - name: m2-cache
    emptyDir: {}
"""
        }
    }

    environment {
        APP_NAME = "hello-microservice"
    }

    stages {
        stage('Compile & Package') {
            steps {
                container('java-agent') {
                    // Path is relative to contextDir (Day5/CICD)
                    dir('Day5/CICD/hello-springboot-microservice') {
                        sh "mvn clean package -DskipTests"
                    } 
                }
            }
        }

        stage('Build Custom Image') {
            steps {
                container('oc-client') {
                    script {
                        openshift.withCluster() {
                            openshift.withProject() {
                                if (!openshift.selector("bc", "hello-microservice-binary").exists()) {
                                    echo "Binary BuildConfig not found. Creating it now..."
                                    openshift.newBuild("--name=hello-microservice-binary", 
                                                       "--strategy=source", 
                                                       "--binary=true", 
                                                       "--image=registry.access.redhat.com/ubi8/openjdk-17:latest")
                                }

                                openshift.selector("bc", "hello-microservice-binary").startBuild(
                                    "--from-dir=hello-springboot-microservice/target/", 
                                    "--wait"
                                )
                        
                                def tag = "build-${env.BUILD_NUMBER}"
                                openshift.tag("hello-microservice-binary:latest", "hello-microservice:${tag}")
                                // FIXED: Added missing quote and parenthesis
                                echo "Image successfully tagged as hello-microservice:${tag}"
                            }
                        }
                    }
                }
            }
        }

        stage('Deploy to OpenShift') {
            steps {
                container('oc-client') {
                    script {
                        openshift.withCluster() {
                            openshift.withProject() {
                                // Path is relative to contextDir (Day5/CICD)
                                dir('openshift') {
                                    sh "oc apply -f hello-deploy.yml"
                                    sh "oc apply -f hello-service.yml"
                                    sh "oc apply -f hello-route.yml"
                                }

                                def tag = "build-${env.BUILD_NUMBER}"
                                sh "oc set image deployment/${APP_NAME} ${APP_NAME}=image-registry.openshift-image-registry.svc:5000/\$(oc project -q)/${APP_NAME}:${tag}"
                                
                                openshift.selector("deployment", APP_NAME).rollout().status()
                            }
                        }
                    }
                }
            }
        }
    }
}
